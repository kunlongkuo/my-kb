{
  "manifest_version": 3,
  "name": "YT to Obsidian Notes",
  "version": "1.0",
  "description": "Convert YouTube videos to Obsidian notes with one click.",
  "permissions": ["activeTab", "clipboardWrite"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch?v=*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
